<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= student.full_name %> — Marks</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar">
    <span class="nav-brand">📊 Student Marks</span>
    <a href="/admin/dashboard" class="btn btn-sm">← Dashboard</a>
  </nav>

  <div class="container" style="max-width:800px">

    <!-- Student Info Card -->
    <div class="card student-info-card">
      <div class="student-info-grid">
        <div class="student-avatar">
          <%= student.full_name.charAt(0).toUpperCase() %>
        </div>
        <div>
          <h2><%= student.full_name %></h2>
          <p style="color:#888">@<%= student.username %></p>
          <span class="status-badge <%= student.is_blocked ? 'status-blocked' : 'status-active' %>">
            <%= student.is_blocked ? '🚫 Blocked' : '✅ Active' %>
          </span>
        </div>
        <div class="rank-display">
          <div class="rank-number">
            <%= rank <= 3 ? (rank===1?'🥇':rank===2?'🥈':'🥉') : '#'+rank %>
          </div>
          <div style="font-size:13px;color:#888">সার্বিক র‍্যাঙ্ক</div>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats-grid">
        <div class="stat-box">
          <div class="stat-num"><%= results.length %></div>
          <div class="stat-label">মোট পরীক্ষা</div>
        </div>
        <div class="stat-box">
          <% const bestResult = results.length ? results.reduce((a,b) => a.percentage>b.percentage?a:b) : null; %>
          <div class="stat-num" style="color:#48bb78">
            <%= bestResult ? parseFloat(bestResult.percentage).toFixed(1)+'%' : '—' %>
          </div>
          <div class="stat-label">সেরা ফলাফল</div>
        </div>
        <div class="stat-box">
          <% const avgPct = results.length
               ? (results.reduce((s,r)=>s+parseFloat(r.percentage),0)/results.length).toFixed(1)
               : null; %>
          <div class="stat-num" style="color:#667eea">
            <%= avgPct ? avgPct+'%' : '—' %>
          </div>
          <div class="stat-label">গড় ফলাফল</div>
        </div>
        <div class="stat-box">
          <% const lastResult = results.length ? results[0] : null; %>
          <div class="stat-num" style="color:#f6ad55">
            <%= lastResult ? parseFloat(lastResult.percentage).toFixed(1)+'%' : '—' %>
          </div>
          <div class="stat-label">সর্বশেষ</div>
        </div>
      </div>
    </div>

    <!-- Exam History -->
    <div class="card">
      <h3>📋 পরীক্ষার ইতিহাস</h3>
      <% if (results.length === 0) { %>
        <p class="empty-msg">এই student এখনো কোনো পরীক্ষা দেয়নি।</p>
      <% } else { %>
        <table class="marks-table">
          <thead>
            <tr>
              <th>#</th>
              <th>তারিখ ও সময়</th>
              <th>স্কোর</th>
              <th>শতাংশ</th>
              <th>ফলাফল</th>
            </tr>
          </thead>
          <tbody>
            <% results.forEach((r, i) => {
               const pct = parseFloat(r.percentage);
            %>
            <tr>
              <td style="color:#aaa"><%= i+1 %></td>
              <td style="font-size:13px">
                <%= new Date(r.submitted_at).toLocaleString('bn-BD', {
                  year:'numeric', month:'short', day:'numeric',
                  hour:'2-digit', minute:'2-digit'
                }) %>
              </td>
              <td><strong><%= r.score %></strong>/<%= r.total %></td>
              <td>
                <div class="mini-bar">
                  <div class="mini-fill"
                       style="width:<%= pct %>%;background:<%= pct>=70?'#48bb78':pct>=40?'#f6ad55':'#fc8181' %>">
                  </div>
                  <span class="mini-label"><%= pct.toFixed(1) %>%</span>
                </div>
              </td>
              <td>
                <span class="result-verdict-badge
                  <%= pct>=70?'verdict-pass':pct>=40?'verdict-avg':'verdict-fail' %>">
                  <%= pct>=70 ? '✅ পাস' : pct>=40 ? '⚠️ গড়' : '❌ ফেল' %>
                </span>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div style="text-align:center;padding-bottom:30px">
      <a href="/admin/dashboard" class="btn btn-primary">← Dashboard এ ফিরে যাও</a>
    </div>
  </div>
</body>
</html>