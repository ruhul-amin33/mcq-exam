<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Login — MCQ Exam</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="auth-page">
  <div class="auth-box">
    <div class="auth-logo">🎓</div>
    <h2>Student Login</h2>

    <!-- <% if (typeof query !== 'undefined' && query && query.registered) { %> -->
      <!-- <div class="alert alert-success">✅ Account তৈরি হয়েছে! এখন login করো।</div> -->
    <!-- <% } %> -->

    <%
      const qs = locals.query || {};
    %>
    <% if (qs.registered) { %>
      <div class="alert alert-success">✅ Account তৈরি হয়েছে! এখন login করো।</div>
    <% } %>


<!-- <% if (locals.query && locals.query.registered) { %> -->
  <!-- <div class="alert alert-success">✅ Account তৈরি হয়েছে! এখন login করো।</div> -->
<!-- <% } %> -->


    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form action="/exam/login" method="POST">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="তোমার username" required>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Login করো</button>
    </form>

    <div class="auth-links">
      <p> <a href="/exam/register">Create a new account→</a></p>
      <p><a href="/admin/login" style="font-size:12px;color:#aaa;">Admin Login</a></p>
    </div>
  </div>
</body>
</html>